{
  "name": "@illuma/reflect",
  "description": "Illuma plugin for reflect-metadata based dependency injection",
  "author": "bebrasmell",
  "repository": {
    "type": "git",
    "url": "https://github.com/git-illuma/reflect"
  },
  "version": "1.3.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "private": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "di",
    "dependency",
    "injection",
    "reflect",
    "angular",
    "typescript",
    "decorators",
    "provider",
    "module",
    "inversion-of-control"
  ],
  "scripts": {
    "test": "vitest run",
    "test:badges": "vitest run --coverage && make-coverage-badge --report-path ./artifacts/coverage/coverage-summary.json --output-path ./badges/coverage.svg",
    "build": "tsup",
    "lint": "biome check",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "@illuma/core": "^1.3.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@illuma/core": "^1.3.1",
    "@swc/core": "^1.15.21",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "^4.1.2",
    "make-coverage-badge": "1.2.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "8.5.1",
    "typescript": "5.9.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "bun@1.2.0"
}
